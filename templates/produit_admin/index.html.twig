{% extends 'base.html.twig' %}

{% block body %}

    <div class="container mt-4">

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2>Gestion des Produits</h2>

            <a href="{{ path('app_produit_admin_new') }}" class="btn btn-primary">
                + Ajouter Produit
            </a>
        </div>

        <div class="card shadow-sm">
            <div class="card-body table-responsive">

                <table class="table table-hover align-middle">

                    <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Image</th>
                        <th>Nom</th>
                        <th>Prix</th>
                        <th>Stock</th>
                        <th>Actions</th>
                    </tr>
                    </thead>

                    <tbody>
                    {% for produit in produits %}
                        <tr>
                            <td>{{ produit.id }}</td>

                            <td>
                                <img src="https://picsum.photos/80/60?random={{ produit.id }}"
                                     class="rounded">
                            </td>

                            <td><strong>{{ produit.nom }}</strong></td>

                            <td>
                            <span class="badge bg-success">
                                {{ produit.prix }} DT
                            </span>
                            </td>

                            <td>
                            <span class="badge bg-info text-dark">
                                {{ produit.stock }}
                            </span>
                            </td>

                            <td>

                                <a href="{{ path('app_produit_admin_show', {'id': produit.id}) }}"
                                   class="btn btn-sm btn-success">
                                    Voir
                                </a>

                                <a href="{{ path('app_produit_admin_edit', {'id': produit.id}) }}"
                                   class="btn btn-sm btn-warning">
                                    Edit
                                </a>

                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6" class="text-center text-muted">
                                Aucun produit trouvé
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>

                </table>

            </div>
        </div>

    </div>

{% endblock %}
