{% extends 'base.html.twig' %}

{% block title %}Modifier {{ user.prenom }} {{ user.nom }}{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="card" style="max-width: 500px;">
        <div class="card-header"><strong>Modifier l'utilisateur</strong></div>
        <div class="card-body">
            {{ include('user/_form.html.twig', {'button_label': 'Enregistrer'}) }}
        </div>
    </div>

    <div class="mt-3">
        <a href="{{ path('app_user_index') }}" class="btn btn-secondary btn-sm">Retour</a>
    </div>
</div>
{% endblock %}