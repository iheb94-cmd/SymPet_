{% extends 'base.html.twig' %}

{% block title %}{{ user.prenom }} {{ user.nom }}{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="card" style="max-width: 500px;">
        <div class="card-header"><strong>Détail utilisateur</strong></div>
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-4">ID</dt>
                <dd class="col-8">{{ user.id }}</dd>

                <dt class="col-4">Email</dt>
                <dd class="col-8">{{ user.email }}</dd>

                <dt class="col-4">Nom</dt>
                <dd class="col-8">{{ user.nom }}</dd>

                <dt class="col-4">Prénom</dt>
                <dd class="col-8">{{ user.prenom }}</dd>

                <dt class="col-4">Rôle</dt>
                <dd class="col-8">
                    {% if 'ROLE_ADMIN' in user.roles %}
                        <span class="badge bg-danger">Admin</span>
                    {% else %}
                        <span class="badge bg-secondary">Utilisateur</span>
                    {% endif %}
                </dd>
            </dl>
        </div>
    </div>

    <div class="mt-3">
        <a href="{{ path('app_user_index') }}" class="btn btn-secondary btn-sm">Retour</a>
        <a href="{{ path('app_user_edit', {'id': user.id}) }}" class="btn btn-warning btn-sm">Modifier</a>
    </div>
</div>
{% endblock %}