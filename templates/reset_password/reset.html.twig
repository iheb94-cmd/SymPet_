{% extends 'base.html.twig' %}

{% block title %}Nouveau mot de passe — SymPet{% endblock %}

{% block body %}
    <div class="container-fluid min-vh-100 d-flex align-items-center justify-content-center" style="background:#f0f4f0;">
        <div class="card shadow-sm border-0" style="width:100%;max-width:440px;border-radius:16px;overflow:hidden;">

            <div class="text-center text-white py-4 px-4" style="background:#2d6a4f;">
                <div style="font-size:40px;">🔐</div>
                <div style="font-size:24px;font-weight:700;letter-spacing:1px;">
                    Sym<span style="color:#b7e4c7;">Pet</span>
                </div>
                <p class="mb-0 mt-1" style="font-size:13px;opacity:.85;">Choisir un nouveau mot de passe</p>
            </div>

            <div class="card-body px-4 py-4">

                {% for flash_error in app.flashes('reset_password_error') %}
                    <div class="alert alert-danger d-flex align-items-center gap-2" role="alert">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                        {{ flash_error }}
                    </div>
                {% endfor %}

                <div class="d-flex align-items-center gap-2 mb-4 p-3"
                     style="background:#f0fff4;border-left:4px solid #40916c;border-radius:8px;font-size:14px;color:#276749;">
                    <i class="bi bi-shield-lock-fill" style="font-size:18px;flex-shrink:0;"></i>
                    <span>Choisissez un mot de passe <strong>fort et unique</strong> d'au moins 6 caractères.</span>
                </div>

                {{ form_start(resetForm, {'attr': {'novalidate': 'novalidate'}}) }}

                <div class="mb-3">
                    <label class="form-label fw-semibold" style="font-size:14px;">
                        <i class="bi bi-lock me-1" style="color:#40916c;"></i>Nouveau mot de passe
                    </label>
                    {{ form_widget(resetForm.plainPassword.first, {
                        'attr': {
                            'class': 'form-control',
                            'placeholder': 'Minimum 6 caractères',
                            'style': 'border-color:#c8dfc8;border-radius:8px;'
                        }
                    }) }}
                    {{ form_errors(resetForm.plainPassword.first) }}
                </div>

                <div class="mb-4">
                    <label class="form-label fw-semibold" style="font-size:14px;">
                        <i class="bi bi-lock-fill me-1" style="color:#40916c;"></i>Confirmer le mot de passe
                    </label>
                    {{ form_widget(resetForm.plainPassword.second, {
                        'attr': {
                            'class': 'form-control',
                            'placeholder': 'Répétez votre mot de passe',
                            'style': 'border-color:#c8dfc8;border-radius:8px;'
                        }
                    }) }}
                    {{ form_errors(resetForm.plainPassword.second) }}
                </div>

                <button type="submit" class="btn w-100 text-white fw-semibold py-2"
                        style="background:#2d6a4f;border-radius:50px;font-size:15px;border:none;transition:background .2s;"
                        onmouseover="this.style.background='#40916c'"
                        onmouseout="this.style.background='#2d6a4f'">
                    <i class="bi bi-check-circle me-2"></i>Réinitialiser mon mot de passe
                </button>

                {{ form_end(resetForm) }}

            </div>

            <div class="text-center py-3 px-4" style="background:#f7faf8;border-top:1px solid #e8f0e8;font-size:14px;color:#4a5568;">
                <a href="{{ path('app_login') }}" style="color:#40916c;font-weight:600;text-decoration:none;">
                    <i class="bi bi-arrow-left me-1"></i>Retour à la connexion
                </a>
            </div>

        </div>
    </div>
{% endblock %}
