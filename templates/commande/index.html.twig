{% extends 'base.html.twig' %}

{% block title %}Gestion Commandes{% endblock %}

{% block body %}

<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=DM+Mono:wght@500&display=swap" rel="stylesheet">

<style>
    :root {
        --bg: #f5f6fa; --card: #fff; --border: #e8eaf0;
        --text: #1a1d2e; --muted: #8b90a7; --accent: #4f6ef7;
        --radius: 14px; --shadow: 0 2px 12px rgba(0,0,0,0.06);
    }
    body { background: var(--bg); font-family: 'DM Sans', sans-serif; color: var(--text); }

    .page-header {
        display: flex; align-items: center;
        justify-content: space-between;
        margin-bottom: 24px; flex-wrap: wrap; gap: 12px;
    }
    .page-title { font-size: 1.5rem; font-weight: 600; margin: 0; }
    .page-title span { color: var(--accent); }

    /* Filter bar */
    .filter-bar {
        display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
        background: var(--card); border: 1px solid var(--border);
        border-radius: var(--radius); padding: 8px 14px;
    }
    .filter-bar label { font-size: .8rem; color: var(--muted); font-weight: 500; white-space: nowrap; }
    .filter-bar input[type="date"], .filter-bar select {
        border: 1px solid var(--border); border-radius: 8px;
        padding: 5px 10px; font-family: 'DM Sans', sans-serif;
        font-size: .85rem; color: var(--text);
        background: var(--bg); outline: none;
    }
    .filter-bar input[type="date"]:focus,
    .filter-bar select:focus { border-color: var(--accent); }
    .btn-filter {
        background: var(--accent); color: #fff; border: none;
        border-radius: 8px; padding: 6px 16px;
        font-family: 'DM Sans', sans-serif; font-size: .85rem;
        font-weight: 500; cursor: pointer; transition: opacity .15s;
    }
    .btn-filter:hover { opacity: .88; }
    .btn-reset {
        background: none; border: 1px solid var(--border);
        border-radius: 8px; padding: 5px 12px; font-size: .82rem;
        color: var(--muted); text-decoration: none; display: inline-block;
    }

    /* Stats badges */
    .stats-row { display: flex; gap: 12px; margin-bottom: 24px; flex-wrap: wrap; }
    .stat-pill {
        display: flex; align-items: center; gap: 8px;
        padding: 8px 16px; border-radius: 99px;
        font-size: .83rem; font-weight: 600; cursor: pointer;
        border: 2px solid transparent; text-decoration: none;
        transition: all .15s;
    }
    .stat-pill .count { font-family: 'DM Mono', monospace; }
    .pill-all      { background: #eef1fe; color: var(--accent); border-color: #c7d2fe; }
    .pill-attente  { background: #fff8e6; color: #d97706;       border-color: #fde68a; }
    .pill-cours    { background: #eff6ff; color: #2563eb;       border-color: #bfdbfe; }
    .pill-terminee { background: #f0fdf4; color: #16a34a;       border-color: #bbf7d0; }
    .stat-pill.active { box-shadow: 0 0 0 3px rgba(79,110,247,.18); }

    /* Table */
    .table-card {
        background: var(--card); border: 1px solid var(--border);
        border-radius: var(--radius); box-shadow: var(--shadow); overflow: hidden;
    }
    .table-card table { margin: 0; }
    .table-card thead th {
        background: var(--bg); font-size: .75rem; font-weight: 600;
        color: var(--muted); text-transform: uppercase; letter-spacing: .06em;
        border-bottom: 1px solid var(--border); padding: 12px 16px;
    }
    .table-card tbody td { padding: 13px 16px; vertical-align: middle; font-size: .88rem; border-color: var(--border); }
    .table-card tbody tr:hover { background: #f9fafc; }

    .cmd-id { font-family: 'DM Mono', monospace; color: var(--accent); font-weight: 600; }
    .cmd-date { color: var(--muted); font-size: .82rem; }

    .badge-statut {
        font-size: .72rem; font-weight: 600; padding: 3px 10px;
        border-radius: 99px; white-space: nowrap;
    }
    .badge-EN_ATTENTE { background: #fff8e6; color: #d97706; }
    .badge-EN_COURS   { background: #eff6ff; color: #2563eb; }
    .badge-TERMINEE   { background: #f0fdf4; color: #16a34a; }

    .no-data { text-align: center; padding: 60px; color: var(--muted); font-size: .9rem; }
</style>

<div class="container py-4">

    <div class="page-header">
        <h2 class="page-title">Gestion des <span>Commandes</span></h2>

        <form method="GET" action="{{ path('admin_commandes') }}" class="filter-bar">
            <label>Du</label>
            <input type="date" name="from" value="{{ from }}">
            <label>Au</label>
            <input type="date" name="to" value="{{ to }}">
            <select name="statut">
                <option value="">Tous les statuts</option>
                <option value="EN_ATTENTE" {% if statut == 'EN_ATTENTE' %}selected{% endif %}>⏳ En attente</option>
                <option value="EN_COURS"   {% if statut == 'EN_COURS'   %}selected{% endif %}>🚚 En cours</option>
                <option value="TERMINEE"   {% if statut == 'TERMINEE'   %}selected{% endif %}>✅ Terminées</option>
            </select>
            <button type="submit" class="btn-filter">Filtrer</button>
            <a href="{{ path('admin_commandes') }}" class="btn-reset">Réinitialiser</a>
        </form>
    </div>

    <div class="stats-row">
        <a href="{{ path('admin_commandes', {from: from, to: to}) }}"
           class="stat-pill pill-all {{ statut is null or statut == '' ? 'active' : '' }}">
            Toutes <span class="count">{{ countMap.EN_ATTENTE + countMap.EN_COURS + countMap.TERMINEE }}</span>
        </a>
        <a href="{{ path('admin_commandes', {from: from, to: to, statut: 'EN_ATTENTE'}) }}"
           class="stat-pill pill-attente {{ statut == 'EN_ATTENTE' ? 'active' : '' }}">
            ⏳ En attente <span class="count">{{ countMap.EN_ATTENTE }}</span>
        </a>
        <a href="{{ path('admin_commandes', {from: from, to: to, statut: 'EN_COURS'}) }}"
           class="stat-pill pill-cours {{ statut == 'EN_COURS' ? 'active' : '' }}">
            🚚 En cours <span class="count">{{ countMap.EN_COURS }}</span>
        </a>
        <a href="{{ path('admin_commandes', {from: from, to: to, statut: 'TERMINEE'}) }}"
           class="stat-pill pill-terminee {{ statut == 'TERMINEE' ? 'active' : '' }}">
            ✅ Terminées <span class="count">{{ countMap.TERMINEE }}</span>
        </a>
    </div>

 
    <div class="table-card">
        {% if commandes|length > 0 %}
        <table class="table table-borderless mb-0">
            <thead>
                <tr>
                    
                    <th>Client</th>
                    <th>Date</th>
                    <th>Statut</th>
                </tr>
            </thead>
            <tbody>
                {% for c in commandes %}
                <tr>
                    
                    <td>{{ c.user_email ?? '—' }}</td>
                    <td><span class="cmd-date">{{ c.datecommande|date('d/m/Y H:i') }}</span></td>
                    <td>
                        <span class="badge-statut badge-{{ c.statut }}">
                            {% if c.statut == 'EN_ATTENTE' %}⏳ En attente
                            {% elseif c.statut == 'EN_COURS' %}🚚 En cours
                            {% else %}✅ Terminée{% endif %}
                        </span>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        {% else %}
            <div class="no-data">Aucune commande trouvée pour les filtres sélectionnés.</div>
        {% endif %}
    </div>

</div>

{% endblock %}