{% extends 'base.html.twig' %}

{% block title %}Commande Confirmée — SymPet{% endblock %}

{% block stylesheets %}
    <style>
        .success-wrapper {
            min-height: 75vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 3rem 1rem;
        }

        .success-card {
            background: #fff;
            border: 0.5px solid var(--sp-200);
            border-radius: 20px;
            padding: 3rem 2.5rem;
            max-width: 560px;
            width: 100%;
            box-shadow: 0 8px 40px rgba(31,138,84,0.10);
            text-align: center;
            position: relative;
            overflow: hidden;
        }

        /* Bande verte décorative en haut */
        .success-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 5px;
            background: linear-gradient(90deg, var(--sp-200), var(--sp-400), var(--sp-600));
            border-radius: 20px 20px 0 0;
        }

        /* Cercle icône */
        .success-icon-wrap {
            width: 90px;
            height: 90px;
            border-radius: 50%;
            background: var(--sp-50);
            border: 3px solid var(--sp-200);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.5rem;
            animation: popIn 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275) both;
        }

        @keyframes popIn {
            0%   { transform: scale(0); opacity: 0; }
            100% { transform: scale(1); opacity: 1; }
        }

        .success-icon-wrap i {
            font-size: 2.8rem;
            color: var(--sp-400);
        }

        /* Titre */
        .success-title {
            font-family: 'Fraunces', serif;
            font-size: 1.75rem;
            font-weight: 600;
            color: var(--sp-800);
            margin-bottom: 0.6rem;
        }

        .success-subtitle {
            font-size: 0.92rem;
            color: var(--sp-600);
            line-height: 1.6;
            margin-bottom: 2rem;
        }

        /* Séparateur */
        .success-divider {
            height: 1px;
            background: var(--sp-100);
            margin: 1.8rem 0;
        }

        /* Étapes de livraison */
        .steps-row {
            display: flex;
            justify-content: space-between;
            gap: 8px;
            margin-bottom: 2rem;
        }

        .step-item {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 6px;
        }

        .step-icon {
            width: 44px;
            height: 44px;
            border-radius: 12px;
            background: var(--sp-50);
            border: 1.5px solid var(--sp-200);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--sp-400);
            font-size: 1.2rem;
        }

        .step-icon.done {
            background: var(--sp-100);
            border-color: var(--sp-400);
            color: var(--sp-600);
        }

        .step-label {
            font-size: 0.72rem;
            font-weight: 600;
            color: var(--sp-600);
            text-align: center;
            line-height: 1.3;
        }

        .step-connector {
            flex: 0 0 20px;
            height: 2px;
            background: var(--sp-200);
            align-self: center;
            margin-top: -14px;
        }

        /* Info box */
        .info-box {
            background: var(--sp-50);
            border: 1px solid var(--sp-100);
            border-radius: 12px;
            padding: 1rem 1.2rem;
            display: flex;
            align-items: flex-start;
            gap: 10px;
            text-align: left;
            margin-bottom: 2rem;
        }

        .info-box i {
            color: var(--sp-400);
            font-size: 1.1rem;
            margin-top: 2px;
            flex-shrink: 0;
        }

        .info-box p {
            margin: 0;
            font-size: 0.85rem;
            color: var(--sp-800);
            line-height: 1.5;
        }

        .info-box p strong { color: var(--sp-600); }

        /* Boutons */
        .actions-row {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }

        .btn-home {
            flex: 1;
            background: var(--sp-400);
            color: #fff;
            border: none;
            border-radius: 10px;
            padding: 12px 16px;
            font-size: 0.9rem;
            font-weight: 700;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 7px;
            text-decoration: none;
            transition: background 0.15s;
            font-family: 'DM Sans', sans-serif;
        }

        .btn-home:hover { background: var(--sp-600); color: #fff; }

        .btn-ghost {
            flex: 1;
            background: transparent;
            color: var(--sp-600);
            border: 1.5px solid var(--sp-200);
            border-radius: 10px;
            padding: 11px 16px;
            font-size: 0.88rem;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 7px;
            text-decoration: none;
            transition: background 0.15s;
            font-family: 'DM Sans', sans-serif;
        }

        .btn-ghost:hover { background: var(--sp-50); color: var(--sp-800); }

        /* Confetti petites pattes décoratives */
        .deco-paw {
            position: absolute;
            font-size: 1.3rem;
            opacity: 0.08;
            pointer-events: none;
            user-select: none;
        }
    </style>
{% endblock %}

{% block body %}

    <div class="success-wrapper">
        <div class="success-card">

            <!-- Pattes décoratives -->
            <span class="deco-paw" style="top:20px; right:24px; transform:rotate(20deg)">🐾</span>
            <span class="deco-paw" style="bottom:30px; left:20px; transform:rotate(-15deg)">🐾</span>

            <!-- Icône succès -->
            <div class="success-icon-wrap">
                <i class="ti ti-circle-check"></i>
            </div>

            <!-- Titre -->
            <h1 class="success-title">Commande confirmée !</h1>
            <p class="success-subtitle">
                Merci pour votre achat sur SymPet 🐾<br>
                Votre commande a bien été enregistrée et sera traitée dans les plus brefs délais.
            </p>

            <!-- Étapes livraison -->
            <div class="steps-row">
                <div class="step-item">
                    <div class="step-icon done">
                        <i class="ti ti-check" style="font-size:1rem"></i>
                    </div>
                    <div class="step-label">Commande<br>validée</div>
                </div>
                <div class="step-connector"></div>
                <div class="step-item">
                    <div class="step-icon">
                        <i class="ti ti-package"></i>
                    </div>
                    <div class="step-label">En cours de<br>préparation</div>
                </div>
                <div class="step-connector"></div>
                <div class="step-item">
                    <div class="step-icon">
                        <i class="ti ti-truck"></i>
                    </div>
                    <div class="step-label">En route<br>vers vous</div>
                </div>
                <div class="step-connector"></div>
                <div class="step-item">
                    <div class="step-icon">
                        <i class="ti ti-home"></i>
                    </div>
                    <div class="step-label">Livraison<br>à domicile</div>
                </div>
            </div>

            <div class="success-divider"></div>

            <!-- Info box -->
            <div class="info-box">
                <i class="ti ti-clock"></i>
                <p>
                    <strong>Délai estimé :</strong> 24 à 48 heures ouvrées.<br>
                    Vous recevrez une confirmation dès l'expédition de votre colis.
                </p>
            </div>

            <!-- Boutons actions -->
            <div class="actions-row">
                <a href="{{ path('app_produits') }}" class="btn-home">
                    <i class="ti ti-shopping-bag"></i> Continuer mes achats
                </a>
            </div>

        </div>
    </div>

{% endblock %}
