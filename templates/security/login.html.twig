{% extends 'base.html.twig' %}

{% block title %}Connexion — SymPet{% endblock %}

{% block body %}
    <div class="container-fluid min-vh-100 d-flex align-items-center justify-content-center"
         style="background:#f0f4f0;">
        <div class="card shadow-sm border-0" style="width:100%;max-width:440px;border-radius:16px;overflow:hidden;">
            <div class="text-center text-white py-4 px-4" style="background:#2d6a4f;">
                <div style="font-size:40px;">🐾</div>
                <div style="font-size:24px;font-weight:700;letter-spacing:1px;">
                    Sym<span style="color:#b7e4c7;">Pet</span>
                </div>
                <p class="mb-0 mt-1" style="font-size:13px;opacity:.85;">Connectez-vous à votre compte</p>
            </div>

            <div class="card-body px-4 py-4">

                {% if app.user %}
                    <div class="alert alert-success d-flex align-items-center gap-2" role="alert">
                        <i class="bi bi-person-check-fill"></i>
                        Connecté en tant que <strong>{{ app.user.userIdentifier }}</strong>.
                        <a href="{{ logout_path() }}" class="ms-auto text-danger fw-semibold text-decoration-none">Déconnexion</a>
                    </div>
                {% endif %}

                {% if error %}
                    <div class="alert alert-danger d-flex align-items-center gap-2" role="alert">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                        {{ error.messageKey|trans(error.messageData, 'security') }}
                    </div>
                {% endif %}

                <form method="post" action="{{ path('app_login') }}">

                    <div class="mb-3">
                        <label for="inputEmail" class="form-label fw-semibold" style="font-size:14px;">
                            <i class="bi bi-envelope me-1" style="color:#40916c;"></i>Adresse email
                        </label>
                        <input
                            type="email"
                            value="{{ last_username }}"
                            name="email"
                            id="inputEmail"
                            class="form-control"
                            placeholder="exemple@email.com"
                            autocomplete="email"
                            required
                            autofocus
                            style="border-color:#c8dfc8;border-radius:8px;"
                        >
                    </div>

                    <div class="mb-3">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <label for="inputPassword" class="form-label fw-semibold mb-0" style="font-size:14px;">
                                <i class="bi bi-lock me-1" style="color:#40916c;"></i>Mot de passe
                            </label>

                        </div>
                        <input
                            type="password"
                            name="password"
                            id="inputPassword"
                            class="form-control"
                            placeholder="••••••••"
                            autocomplete="current-password"
                            required
                            style="border-color:#c8dfc8;border-radius:8px;"
                        >
                    </div>

                    <input type="hidden" name="_csrf_token"
                           data-controller="csrf-protection"
                           value="{{ csrf_token('authenticate') }}">

                    <div class="mb-4 form-check">
                        <input type="checkbox" class="form-check-input" name="_remember_me" id="rememberMe"
                               style="border-color:#40916c;">
                        <label class="form-check-label" for="rememberMe" style="font-size:14px;color:#4a5568;">
                            Se souvenir de moi
                        </label>
                    </div>

                    <button type="submit" class="btn w-100 text-white fw-semibold py-2"
                            style="background:#2d6a4f;border-radius:50px;font-size:15px;border:none;transition:background .2s;"
                            onmouseover="this.style.background='#40916c'"
                            onmouseout="this.style.background='#2d6a4f'">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Se connecter
                    </button><br>
                    <a href="{{ path('connect_google') }}" style="display:flex;align-items:center;justify-content:center;gap:10px;padding:10px 16px;background:transparent;text-decoration:none;color:#3c4043;font-size:14px;font-weight:500;width:100%;">
                        <svg width="18" height="18" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
                            <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
                            <path fill="#4285F4" d="M46.98 24.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
                            <path fill="#FBBC05" d="M10.53 28.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
                            <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
                        </svg>
                        Google
                    </a>
                </form>
            </div>
            <div class="text-center py-3 px-4"
                 style="background:#f7faf8;border-top:1px solid #e8f0e8;font-size:14px;color:#4a5568;">
                Pas encore de compte ?
                <a href="{{ path('app_register') }}" style="color:#40916c;font-weight:600;text-decoration:none;">
                    " S'inscrire"
                </a><br>
                <a href="{{ path('app_forgot_password_request') }}"
                   style="font-size:13px;color:#40916c;text-decoration:none;">
                    Mot de passe oublié ?
                </a>

            </div>
        </div>
    </div>
{% endblock %}
