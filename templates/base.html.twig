
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}SymPet{% endblock %}</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@400;600&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">

    <!-- Tabler Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@2.44.0/tabler-icons.min.css">

    {% block stylesheets %}{% endblock %}

    <style>
        /* ===== PALETTE VERTE SYMPET ===== */
        :root {
            --sp-50:   #edfaf3;
            --sp-100:  #c6f0d8;
            --sp-200:  #8eddb4;
            --sp-400:  #3db87a;
            --sp-600:  #1f8a54;
            --sp-800:  #0f5433;
            --sp-900:  #072e1c;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background-color: var(--sp-50);
            color: var(--sp-800);
        }

        /* ===== NAVBAR ===== */
        .sympet-nav {
            background-color: var(--sp-800);
            padding: 0 2rem;
            height: 64px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            box-shadow: 0 2px 12px rgba(15, 84, 51, 0.20);
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .sympet-brand {
            font-family: 'Fraunces', serif;
            font-size: 1.5rem;
            font-weight: 600;
            color: var(--sp-50);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .sympet-brand:hover { color: var(--sp-100); }

        .sympet-brand-icon {
            width: 38px;
            height: 38px;
            border-radius: 10px;
            background: var(--sp-400);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.25rem;
        }

        .nav-link-sp {
            color: var(--sp-100) !important;
            font-size: 0.9rem;
            font-weight: 500;
            text-decoration: none;
            opacity: 0.85;
            transition: opacity 0.15s;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .nav-link-sp:hover { opacity: 1; color: #fff !important; }

        .nav-badge-sp {
            background: var(--sp-400);
            color: #fff;
            font-size: 0.68rem;
            font-weight: 700;
            border-radius: 99px;
            padding: 2px 7px;
        }

        /* ===== FOOTER ===== */
        .sympet-footer {
            background-color: var(--sp-800);
            color: var(--sp-100);
            text-align: center;
            padding: 1.2rem;
            font-size: 0.85rem;
            margin-top: 3rem;
            bottom: 0;
            position: fixed;
            width: 100%;
        }

        .sympet-footer a {
            color: var(--sp-200);
            text-decoration: none;
        }

        /* ===== BOUTONS GLOBAUX ===== */
        .btn-sp-primary {
            background-color: var(--sp-400);
            color: #fff;
            border: none;
            border-radius: 8px;
            padding: 8px 20px;
            font-weight: 600;
            font-size: 0.9rem;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            transition: background 0.15s;
            text-decoration: none;
        }

        .btn-sp-primary:hover { background-color: var(--sp-600); color: #fff; }

        .btn-sp-outline {
            background-color: transparent;
            color: var(--sp-600);
            border: 1.5px solid var(--sp-400);
            border-radius: 8px;
            padding: 7px 18px;
            font-weight: 600;
            font-size: 0.9rem;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            transition: background 0.15s;
            text-decoration: none;
        }

        .btn-sp-outline:hover { background-color: var(--sp-100); color: var(--sp-800); }

        /* ===== FLASH MESSAGES ===== */
        .flash-success {
            background: var(--sp-100);
            border-left: 4px solid var(--sp-400);
            color: var(--sp-800);
            border-radius: 8px;
            padding: 12px 16px;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 8px;
        }
    </style>
</head>
<body>




<!-- ===== FLASH MESSAGES ===== -->
{% for message in app.flashes('success') %}
    <div class="container mt-3">
        <div class="flash-success">
            <i class="ti ti-circle-check"></i> {{ message }}
        </div>
    </div>
{% endfor %}

<!-- ===== CONTENU PRINCIPAL ===== -->
{% include 'partials/navbar.html.twig' %}
<div class="container mt-4">
    {% block body %}{% endblock %}
</div>

<!-- ===== FOOTER ===== -->
<footer class="sympet-footer">
    🐾 SymPet &copy; {{ "now"|date("Y") }} &mdash; Tout pour vos animaux
</footer>

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

{% block javascripts %}
    {% block importmap %}{{ importmap('app') }}{% endblock %}
{% endblock %}

</body>
</html>
