{% extends 'base.html.twig' %}

{% block body %}

    <div class="container mt-4">

        <div class="card">

            <div class="card-body">

                <h3>{{ categorie.nom }}</h3>

                <p class="text-muted">
                    {{ categorie.description }}
                </p>

                <div class="mt-3 d-flex gap-2">

                    <a href="{{ path('app_categorie_admin_edit', {'id': categorie.id}) }}"
                       class="btn btn-warning">
                        Edit
                    </a>

                    <a href="{{ path('app_categorie_admin_index') }}"
                       class="btn btn-secondary">
                        Back
                    </a>

                </div>

            </div>

        </div>

    </div>

{% endblock %}
